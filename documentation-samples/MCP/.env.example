# ---------------------------------------------------------------------------
# Demo credentials for the Olist + StarRocks MCP demo.
#
# Setup:  cp .env.example .env   (then edit .env if you use your own values)
#
# .env is gitignored; .env.example is committed as the template. The MCP
# servers in .mcp.json load this file directly (docker --env-file for aistor,
# a `set -a; source` wrapper for the StarRocks uv server), so it works whether
# Claude Code is launched from a terminal or the Desktop app.
#
# The values below are the *compose-provisioned demo defaults* — fine to use
# as-is for the local demo. Replace them in your .env if you generated your own
# MinIO keys or changed ports.
# ---------------------------------------------------------------------------

# --- MinIO / aistor MCP server ---
# host.docker.internal (not localhost): the aistor MCP runs in its own container.
MINIO_ENDPOINT=host.docker.internal:9000
# Root (admin) login for the MinIO server + `mc` alias in docker-compose.yml.
MINIO_ROOT_USER=miniouser
MINIO_ROOT_PASSWORD=M!n10R0cks
# Service-account access key (created by the minio_mc bootstrap) used by StarRocks.
MINIO_ACCESS_KEY=AAAAAAAAAAAAAAAAAAAA
MINIO_SECRET_KEY=BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB
MINIO_USE_SSL=false

# --- StarRocks MCP server ---
# Format: user:password@host:port/database  (demo root has no password)
STARROCKS_URL=root:@localhost:9030/olist

# --- Plotly chart output (PR #43: HTML output for query_and_plotly_chart) ---
# Interactive HTML charts (+ a PNG preview) are written here. Anchored to the
# project root via ${CLAUDE_PROJECT_DIR} so it resolves the same from a terminal
# or the Desktop app. NOTE: the StarRocks server bash-sources this file, so the
# variable expands here; the aistor container loads .env via `docker --env-file`
# (no expansion) but ignores these vars, so that's harmless.
STARROCKS_CHART_OUTPUT_DIR=${CLAUDE_PROJECT_DIR:-.}/DEMO_Output
# How plotly.js is bundled into the HTML: cdn (default; smallest, needs internet
# to render) | inline (self-contained, works offline) | directory.
# STARROCKS_CHART_INCLUDE_PLOTLYJS=inline
